{
  "schemaVersion": 1,
  "id": "seamless_crafting",
  "version": "${version}",

  "name": "Seamless Crafting",
  "description": "Craft straight from nearby chests with a clean nearby-items panel, recipe book support, and chest highlighting.",
  "icon": "assets/seamless_crafting/icon.png",
  "authors": [
    "Derk Ottersberg"
  ],
  "contact": {
    "issues": "https://github.com/DerkOttersberg/Seamless-Crafting/issues",
    "sources": "https://github.com/DerkOttersberg/Seamless-Crafting"
  },

  "license": "CC0-1.0",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.derk.seamlesscrafting.SeamlessCraftingMod"
    ],
    "client": [
      "com.derk.seamlesscrafting.SeamlessCraftingClient"
	],
	"modmenu": [
	  "com.derk.seamlesscrafting.client.SeamlessCraftingModMenu"
    ]
  },
  "mixins": [
    "seamlesscrafting.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.18.4",
    "fabric": "*",
    "minecraft": ">=1.21.11"
  },
  "suggests": {
	"modmenu": "*"
  }
}

