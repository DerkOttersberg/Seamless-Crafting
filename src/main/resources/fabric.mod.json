{
  "schemaVersion": 1,
  "id": "derk_easy_inventory_crafter",
  "version": "${version}",

  "name": "Bluethooth Chest",
  "description": "Craft straight from nearby chests with a clean nearby-items panel, recipe book support, and chest highlighting.",
  "authors": [
    "Derk"
  ],
  "contact": {
    "sources": "https://github.com/DerkOttersberg/bluethooth-chest"
  },

  "license": "CC0-1.0",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.derk.easyinventorycrafter.EasyInventoryCrafterMod"
    ],
    "client": [
      "com.derk.easyinventorycrafter.EasyInventoryCrafterClient"
    ],
    "modmenu": [
      "com.derk.easyinventorycrafter.client.EasyInventoryCrafterModMenu"
    ]
  },
  "mixins": [
    "easyinventorycrafter.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.14.21",
    "fabric": "*",
    "minecraft": ">=1.20"
  },
  "suggests": {
    "modmenu": "*"
